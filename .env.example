# ─── Firebase ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Firebase Cloud Messaging (FCM) ──────────────────────────────
# VAPID keys untuk Firebase Push Notification
# Generate via: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Firebase Admin Service Account (untuk server-side FCM)
# Dapatkan dari: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT=

# ─── Upstash QStash ──────────────────────────────────────────────
# Dapatkan dari: https://console.upstash.com/qstash
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Webhook URL untuk menerima trigger dari QStash (deployment URL Vercel)
# Contoh: https://jadhuman.vercel.app/api/qstash-webhook
QSTASH_WEBHOOK_URL=

# ─── Enkripsi ────────────────────────────────────────────────────
# Kunci AES untuk enkripsi credential di Firestore (pakai di sisi client)
VITE_APP_SECRET=

# Kunci payload layered encryption (Vigenere-like, pakai di sisi client)
VITE_PAYLOAD_KEY=

# ─── Server (Node.js proxy) ───────────────────────────────────────
# Port server Express (default: 3000)
PORT=3000

# IP/hostname server absensi (default: 103.109.206.102)
ABSENSI_BASE_HOST=103.109.206.102

# Origin yang diizinkan akses proxy, pisahkan dengan koma
# Contoh production: https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
